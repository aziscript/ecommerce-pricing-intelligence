      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "container_memory_working_set_bytes{\n  container=~\"kafka|zookeeper|minio|prometheus|grafana\",\n  image!=\"\"\n}",
          "legendFormat": "{{container}}",
