      "title": "Service Health",
      "type": "row"
    },

    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "description": "Prometheus self-reported status. Scraped from localhost:9090. Always 1 (UP) when Prometheus itself is running.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red",   "index": 0 },
                "1": { "text": "UP",   "color": "green", "index": 1 }
              }
            },
            {
              "type": "special",
              "options": {
                "match": "null",
                "result": { "text": "NO DATA", "color": "orange", "index": 2 }
              }
            }
          ],
          "noValue": "NO DATA",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1    }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "name"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "up{job=\"prometheus\"}",
          "instant": true,
          "legendFormat": "Prometheus",
          "refId": "A"
        }
      ],
      "title": "Prometheus",
      "type": "stat"
    },

